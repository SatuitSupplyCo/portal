# Database
DATABASE_URL=postgresql://satuit:satuit_dev@localhost:5432/satuit_portal

# Auth.js — generate secret with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-real-secret
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Optional: restrict Google OAuth to a specific email domain
AUTH_ALLOWED_DOMAIN=satuitsupply.com

# AWS Bedrock (AI) — generate an API key in the Bedrock console
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Studio feature flags
STUDIO_CONCEPTING_ENABLED=false
STUDIO_DESIGN_ENABLED=true
STUDIO_RENDER_ENABLED=true
CONCEPTING_PROVIDER_ENABLED=false
RENDER_PROVIDER_ENABLED=false
# Optional model overrides
CONCEPTING_MODEL_ID=
RENDER_MODEL_ID=

# Optional external image generation provider for render jobs
RENDER_IMAGE_PROVIDER_ENABLED=false
RENDER_IMAGE_PROVIDER_URL=
RENDER_IMAGE_PROVIDER_API_KEY=
RENDER_IMAGE_PROVIDER_TIMEOUT_MS=45000
STUDIO_RENDER_WORKER_ENABLED=true
STUDIO_RENDER_DAILY_JOB_LIMIT=60
STUDIO_CONCEPT_DAILY_JOB_LIMIT=30
STUDIO_CONCEPT_MAX_ACTIVE_JOBS=2

# Studio design asset uploads (S3)
STUDIO_DESIGN_ASSET_BUCKET=
# Optional CDN/public base URL for uploaded assets, e.g. https://cdn.example.com
STUDIO_DESIGN_ASSET_PUBLIC_BASE_URL=
